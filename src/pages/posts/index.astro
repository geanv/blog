---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => data.draft !== true);
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Get all unique tags
const allTags = [...new Set(sortedPosts.flatMap(post => post.data.tags || []))];
---

<BaseLayout title="Blog" description="Blog posts — notes on cloud, networking, and code.">
  <section class="max-w-4xl mx-auto px-6 py-12">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 dark:text-zinc-50 mb-2">
      Blog
    </h1>
    <p class="text-gray-600 dark:text-zinc-400 mb-8">
      {sortedPosts.length} post{sortedPosts.length !== 1 ? 's' : ''}
    </p>

    {allTags.length > 0 && (
      <div class="mb-8 flex flex-wrap gap-2">
        <span class="tag cursor-default">All</span>
        {allTags.map(tag => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}

    <div class="grid gap-4 sm:grid-cols-2">
      {sortedPosts.map(post => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          slug={post.id}
          tags={post.data.tags}
        />
      ))}
    </div>

    {sortedPosts.length === 0 && (
      <div class="text-center py-20 text-gray-400 dark:text-zinc-600">
        <svg class="w-16 h-16 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h8.25m-8.25 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
        </svg>
        <p class="text-lg">No posts yet</p>
        <p class="text-sm mt-2">Coming soon...</p>
      </div>
    )}
  </section>
</BaseLayout>
