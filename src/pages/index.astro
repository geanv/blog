---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => data.draft !== true);
const recentPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Guo Jian" description="Software Engineer & Researcher — thoughts on cloud, networking, and code.">
  <!-- Hero: Name + Bio -->
  <section class="max-w-3xl mx-auto px-6 pt-24 pb-16">
    <p class="text-sm font-medium tracking-widest uppercase text-gray-400 dark:text-zinc-500 mb-4">
      Hello, I'm
    </p>

    <h1 class="text-5xl sm:text-6xl font-extrabold text-gray-900 dark:text-zinc-50 tracking-tight leading-none">
      Guo Jian
    </h1>

    <p class="mt-4 text-xl sm:text-2xl text-gray-600 dark:text-zinc-300 font-medium leading-relaxed">
      Software Engineer @ Huawei Cloud · Ph.D. HUST
    </p>

    <p class="mt-4 text-gray-500 dark:text-zinc-400 leading-relaxed max-w-2xl">
      Datacenter networking, bandwidth allocation &amp; SDN researcher.
      Building cloud infrastructure by day, writing by night.
    </p>

    <!-- Social Links -->
    <div class="mt-8 flex items-center gap-4">
      <a href="https://github.com/geanv" target="_blank" rel="noopener"
         class="inline-flex items-center gap-2 text-sm font-medium text-gray-700 dark:text-zinc-300 hover:text-primary dark:hover:text-primary-dark transition-colors group">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        GitHub
        <svg class="w-3 h-3 opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
      <span class="text-gray-300 dark:text-zinc-700">·</span>
      <a href={`${base}about`}
         class="inline-flex items-center gap-2 text-sm font-medium text-gray-700 dark:text-zinc-300 hover:text-primary dark:hover:text-primary-dark transition-colors group">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
        Publications
        <svg class="w-3 h-3 opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
      <span class="text-gray-300 dark:text-zinc-700">·</span>
      <a href={`${base}about`}
         class="inline-flex items-center gap-2 text-sm font-medium text-gray-700 dark:text-zinc-300 hover:text-primary dark:hover:text-primary-dark transition-colors group">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
        About
        <svg class="w-3 h-3 opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>

    <!-- Divider -->
    <div class="mt-16 border-t border-gray-200 dark:border-zinc-800"></div>
  </section>

  <!-- Recent Writing -->
  {recentPosts.length > 0 && (
    <section class="max-w-3xl mx-auto px-6 pb-20">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-sm font-semibold tracking-widest uppercase text-gray-400 dark:text-zinc-500">
          Recent Writing
        </h2>
        <a href={`${base}posts`}
           class="text-xs font-medium text-gray-500 dark:text-zinc-500 hover:text-primary dark:hover:text-primary-dark transition-colors flex items-center gap-1">
          View all
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

      <ul class="space-y-0">
        {recentPosts.map((post, i) => {
          const formattedDate = post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' });
          return (
            <li class="group">
              <a href={`${base}posts/${post.id}`}
                 class="flex items-baseline gap-4 py-4 border-b border-gray-100 dark:border-zinc-800/80 hover:border-primary/30 dark:hover:border-primary-dark/30 transition-colors">
                <span class="shrink-0 text-xs font-mono text-gray-400 dark:text-zinc-600 tabular-nums w-24">
                  {formattedDate}
                </span>
                <span class="text-gray-900 dark:text-zinc-200 font-medium group-hover:text-primary dark:group-hover:text-primary-dark transition-colors">
                  {post.data.title}
                </span>
                {post.data.tags && post.data.tags.length > 0 && (
                  <span class="hidden sm:inline-block ml-auto shrink-0 tag text-[10px]">
                    {post.data.tags[0]}
                  </span>
                )}
              </a>
            </li>
          );
        })}
      </ul>
    </section>
  )}
</BaseLayout>
