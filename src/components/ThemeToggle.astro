---
// ThemeToggle - single icon, click to cycle: light → auto → dark
---

<button
  type="button"
  class="theme-toggle relative p-2 rounded-lg transition-colors hover:bg-gray-100 dark:hover:bg-zinc-800"
  aria-label="Toggle theme"
>
  <!-- Sun (light mode active) -->
  <svg class="theme-icon w-5 h-5 text-gray-600" data-mode="light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
  </svg>
  <!-- Monitor (auto mode active) -->
  <svg class="theme-icon w-5 h-5 text-gray-600" data-mode="auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
  </svg>
  <!-- Moon (dark mode active) -->
  <svg class="theme-icon w-5 h-5 text-gray-600" data-mode="dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
  </svg>
</button>

<style>
  .theme-icon { display: none; }
  .theme-icon.active { display: block; }
</style>

<script>
  const MODES = ['light', 'auto', 'dark'] as const;

  function applyTheme(mode: string) {
    const html = document.documentElement;
    if (mode === 'dark' || (mode === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      html.classList.add('dark');
    } else {
      html.classList.remove('dark');
    }
    // Show icon for current mode, hide others
    document.querySelectorAll('.theme-icon').forEach(icon => {
      const el = icon as HTMLElement;
      el.classList.toggle('active', el.dataset.mode === mode);
    });
    // Adjust icon color for dark/light
    document.querySelectorAll('.theme-icon.active').forEach(icon => {
      if (html.classList.contains('dark')) {
        icon.classList.remove('text-gray-600');
        icon.classList.add('text-zinc-400');
      } else {
        icon.classList.remove('text-zinc-400');
        icon.classList.add('text-gray-600');
      }
    });
  }

  function initTheme() {
    const saved = localStorage.getItem('theme') || 'auto';
    applyTheme(saved);

    document.querySelectorAll('.theme-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const current = localStorage.getItem('theme') || 'auto';
        const next = MODES[(MODES.indexOf(current as any) + 1) % MODES.length];
        localStorage.setItem('theme', next);
        applyTheme(next);
      });
    });

    // React to system preference changes in auto mode
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
      if ((localStorage.getItem('theme') || 'auto') === 'auto') {
        applyTheme('auto');
      }
    });
  }

  initTheme();
  document.addEventListener('astro:after-swap', initTheme);
</script>
