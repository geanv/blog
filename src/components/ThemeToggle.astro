---
// ThemeToggle component - light / dark / auto (follow system) switcher
---

<div class="theme-switch flex items-center rounded-lg bg-gray-100 dark:bg-zinc-800 p-0.5 gap-0.5">
  <button
    type="button"
    class="theme-btn flex items-center justify-center w-7 h-7 rounded-md transition-all"
    data-theme="light"
    aria-label="Light mode"
    title="浅色"
  >
    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
    </svg>
  </button>
  <button
    type="button"
    class="theme-btn flex items-center justify-center w-7 h-7 rounded-md transition-all"
    data-theme="auto"
    aria-label="Follow system"
    title="跟随系统"
  >
    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
    </svg>
  </button>
  <button
    type="button"
    class="theme-btn flex items-center justify-center w-7 h-7 rounded-md transition-all"
    data-theme="dark"
    aria-label="Dark mode"
    title="深色"
  >
    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
    </svg>
  </button>
</div>

<script>
  function applyTheme(mode: string) {
    const html = document.documentElement;
    if (mode === 'dark' || (mode === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      html.classList.add('dark');
    } else {
      html.classList.remove('dark');
    }
    // Highlight active button
    document.querySelectorAll('.theme-btn').forEach(btn => {
      const isActive = (btn as HTMLElement).dataset.theme === mode;
      btn.classList.toggle('bg-white', isActive);
      btn.classList.toggle('dark:bg-zinc-600', isActive);
      btn.classList.toggle('shadow-sm', isActive);
      btn.classList.toggle('text-gray-700', isActive);
      btn.classList.toggle('dark:text-zinc-200', isActive);
      btn.classList.toggle('text-gray-400', !isActive);
      btn.classList.toggle('dark:text-zinc-500', !isActive);
    });
  }

  function initTheme() {
    const saved = localStorage.getItem('theme') || 'auto';
    applyTheme(saved);

    // Bind clicks
    document.querySelectorAll('.theme-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const mode = (btn as HTMLElement).dataset.theme!;
        localStorage.setItem('theme', mode);
        applyTheme(mode);
      });
    });

    // Listen for system preference changes when in auto mode
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
      if (localStorage.getItem('theme') === 'auto' || !localStorage.getItem('theme')) {
        applyTheme('auto');
      }
    });
  }

  initTheme();
  document.addEventListener('astro:after-swap', initTheme);
</script>
