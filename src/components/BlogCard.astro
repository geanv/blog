---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags?: string[];
}

const { title, description, date, slug, tags = [] } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const base = import.meta.env.BASE_URL;
---

<article class="group">
  <a href={`${base}posts/${slug}`} class="block p-6 rounded-xl border border-gray-200 dark:border-zinc-800 bg-white dark:bg-[#141416] hover:border-primary/30 dark:hover:border-primary-dark/30 hover:shadow-lg hover:shadow-primary/5 dark:hover:shadow-primary-dark/5 transition-all duration-300">
    <time datetime={date.toISOString()} class="text-sm text-gray-500 dark:text-zinc-400">
      {formattedDate}
    </time>
    <h3 class="mt-2 text-lg font-semibold text-gray-900 dark:text-zinc-300 group-hover:text-primary dark:group-hover:text-primary-dark transition-colors">
      {title}
    </h3>
    <p class="mt-2 text-gray-600 dark:text-zinc-400 text-sm leading-relaxed line-clamp-2">
      {description}
    </p>
    {tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-2">
        {tags.map(tag => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
  </a>
</article>
